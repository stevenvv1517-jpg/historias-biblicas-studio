# ============================================================
#  Historias Bíblicas Studio — Variables de entorno
#  Copia este archivo a `.env.local` y rellena tus claves.
#  Nunca subas .env.local a git (ya está en .gitignore).
# ============================================================

# --- Groq (guion + escenas visuales con LLM) ---
# Consíguela en: https://console.groq.com/keys
GROQ_API_KEY=
# Modelo por defecto. Alternativas: llama-3.3-70b-versatile, mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# --- LMNT (voz / TTS) ---
# Consíguela en: https://app.lmnt.com/
LMNT_API_KEY=
# (Opcional) UUID de una voz personalizada/clonada. Si se define,
# tiene prioridad absoluta sobre el selector de la UI.
# Formato: 580e785e-6aa3-4b4c-8c40-a114b0fcba60
LMNT_VOICE_ID=

# --- Deepgram (subtítulos word-level) ---
# Consíguela en: https://console.deepgram.com/
DEEPGRAM_API_KEY=

# --- Cloudflare (Flux text-to-image + Workers AI) ---
# Consíguelas en: https://dash.cloudflare.com/ > Workers AI
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# Modelo de generación de imagen. Por defecto Flux:
CLOUDFLARE_FLUX_MODEL=@cf/black-forest-labs/flux-1-schnell
# (Opcional) Modelo de animación. Por defecto pruna/p-video-animate
CLOUDFLARE_ANIMATE_MODEL=@cf/pruna/p-video-animate

# --- Remotion (render MP4) ---
# Necesario solo si usas paralelización de chromium en producción.
# Para desarrollo local NO hace falta.
# Compra una licencia en https://www.remotion.pro/ si tu empresa supera
# el umbral del plan Company.
REMOTION_LICENSE_KEY=

# --- Google OAuth (inicio de sesión) ---
# Consíguelas en: https://console.cloud.google.com/ > APIs & Services > Credentials > OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- NextAuth (sesión JWT) ---
# Genera una con: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- Backblaze B2 (almacenamiento en la nube) ---
# Crea un bucket privado en https://secure.backblaze.com/b2_buckets.htm
# y completa las siguientes variables. Si no se configuran, la app
# funcionará igual pero solo con almacenamiento local.
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=historias-biblicas-videos
# Ejemplo: https://s3.us-west-004.backblazeb2.com
B2_ENDPOINT=
# Opcional: URL pública con CDN para descargas directas.
# Ejemplo: https://f002.backblazeb2.com/file/historias-biblicas-videos
B2_PUBLIC_URL=

# Pexels (videos de naturaleza para versículos con reflexión)
# Consíguela gratis en: https://www.pexels.com/api/
PEXELS_API_KEY=

# Marca de agua — nombre del canal en la esquina inferior derecha del video
CHANNEL_NAME=Canal Cristiano

# URL pública de tu app (para webhooks o descargas). Opcional en local.
NEXT_PUBLIC_APP_URL=http://localhost:3000
